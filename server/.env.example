# Portal server configuration.
# Copy to .env (or export in your shell) and fill in your own values.
# Every Portal instance runs against ITS OWNER'S wallet: generate one with
# zingo-cli, back up the seed phrase, and paste the receiving address here.

# REQUIRED. Your shielded receiving address (unified address, starts with u1).
PORTAL_ADDRESS=

# Signing key for session JWTs. Generate with: openssl rand -hex 32
# If unset, a secret is generated once and persisted to server/.jwt-secret,
# so sessions still survive a restart even without this set explicitly.
PORTAL_JWT_SECRET=

# Login challenge amount in ZEC. Default 0 (zero-value transaction).
# PORTAL_AMOUNT=0

# Price of the demo VIP gate in ZEC. Default 0.05.
# PORTAL_GATE_VIP_AMOUNT=0.05

# Require a mined confirmation before unlocking the VIP gate, instead of
# accepting it the moment it's seen in the mempool. Default off (0) — turn
# this on (1) for a Gate expensive enough that you don't want to trust 0-conf.
# PORTAL_GATE_VIP_REQUIRE_CONFIRMATION=0

# Where Paylinks, Gates, creator accounts, and Shielded Wall posts are
# persisted to disk. Default: a `data/` folder next to this file.
# PORTAL_DATA_DIR=./data

# Creator accounts (multi-tenant): sign up at POST /creators/register to get
# your own diversified receiving address on this same wallet seed, then
# define your own Gates and Paylinks under it. No extra config needed — see
# docs.html#creators for the full API. Sign-up is capped at 5/IP/hour and
# login at 20/IP/15min, same pattern as the other rate limits below.

# HTTP port. Default 8787.
# PORT=8787

# How the server launches the zingo-cli wallet sidecar.
# Defaults assume Windows + WSL. On Linux/macOS set something like:
# PORTAL_ZINGO_CMD=/home/you/zingolib/target/release/zingo-cli
# PORTAL_ZINGO_ARGS=["--data-dir","/home/you/.portal-wallet"]

# Watcher poll interval in ms. Default 2000.
# PORTAL_POLL_MS=2000
